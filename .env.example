# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the browser / client components.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret partagé du job de nettoyage Storage (route /api/cron/storage-cleanup).
# Doit être identique au secret Vault `storage_cleanup_secret` (cf. migration 0014).
CRON_SECRET=your-cron-secret
