# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the browser / client components.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret partagé des routes déclenchées par pg_net (nettoyage Storage +
# dispatch Web Push). Doit être identique aux secrets Vault `storage_cleanup_secret`
# (migration 0014) et `push_dispatch_secret` (migration 0016).
CRON_SECRET=your-cron-secret

# Web Push (VAPID) — générés via `npx web-push generate-vapid-keys`.
# Clé PUBLIQUE : exposée au navigateur (applicationServerKey du service worker).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# Clé PRIVÉE : SERVEUR UNIQUEMENT — ne jamais exposer au client, ne jamais logger.
VAPID_PRIVATE_KEY=your-vapid-private-key
# Sujet VAPID : contact de l'app (mailto: ou URL). Requis par la spec Web Push.
VAPID_SUBJECT=mailto:notifications@bolingo.app
